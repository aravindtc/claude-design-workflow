{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aravindtc/claude-design-workflow/workflow/asset-schema.json",
  "title": "AssetBrief",
  "description": "A single asset brief produced by the asset-need-engine at stage 05. One brief per section.",
  "type": "object",
  "required": ["section", "need_asset"],
  "properties": {
    "section": {
      "type": "string",
      "description": "Section identifier matching an entry in section_plan."
    },
    "need_asset": {
      "type": "boolean",
      "description": "If false, section is text-only and no further fields are required."
    },
    "asset_type": {
      "enum": ["photo", "vector", "illustration", "abstract_texture", "diagram", "icon"]
    },
    "role": {
      "enum": ["primary_anchor", "supporting", "background", "decorative"],
      "description": "How the asset functions in the layout."
    },
    "style": {
      "type": "string",
      "description": "1-2 line prose describing the desired visual style."
    },
    "mood": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Short mood adjectives (grounded, calm, intelligent, etc)."
    },
    "orientation": {
      "enum": ["landscape", "portrait", "square", "any"]
    },
    "aspect_ratio": {
      "type": "string",
      "pattern": "^\\d+:\\d+$",
      "description": "e.g. '16:9', '4:5'. Optional; orientation alone is usually enough."
    },
    "variants": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20,
      "default": 5,
      "description": "How many final candidates to keep for user approval."
    },
    "avoid": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Specific imagery or cliches to exclude."
    },
    "sources": {
      "type": "array",
      "items": {
        "enum": ["open_web", "unsplash", "pexels", "pixabay", "adobe_stock", "getty", "svgrepo", "iconify", "firecrawl"]
      },
      "description": "Priority-ordered list of sources to query."
    },
    "license_requirements": {
      "enum": ["any", "cc0", "cc_by", "royalty_free_paid", "commercial_only"],
      "default": "any"
    },
    "approval": {
      "type": "object",
      "properties": {
        "status": {
          "enum": ["draft", "in_review", "approved", "rejected"],
          "default": "draft"
        },
        "approved_at": { "type": ["string", "null"], "format": "date-time" },
        "approved_by": { "type": ["string", "null"] },
        "notes": { "type": ["string", "null"] }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "need_asset": { "const": true } } },
      "then": {
        "required": ["asset_type", "role", "variants", "sources"]
      }
    }
  ]
}
